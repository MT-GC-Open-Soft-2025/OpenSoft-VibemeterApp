# Copy this file to .env and fill in real values
# Used by docker-compose.yml and the backend at runtime

# --- Backend configuration ---
# MongoDB connection string (external MongoDB deployment)
# Example (MongoDB Atlas): mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=

# JWT settings
JWT_SECRET=
JWT_ALGORITHM=HS256
TOKEN_EXPIRY_SECONDS=3600

# Database name used by the app
DB_NAME=

# Optional: AI key if features require it
GEMINI_KEY=

# --- Frontend build-time configuration ---
# Base URL the frontend uses to talk to the backend API
# For local docker-compose runs, keep it pointing to the exposed backend port
REACT_APP_API_BASE_URL=http://localhost:8000

# --- Image build/push configuration (optional) ---
# Override the registry/namespace and image names used by scripts/build-and-push.sh
REGISTRY=docker.io/username
BACKEND_IMAGE=docker.io/username/vibemeter-backend
FRONTEND_IMAGE=docker.io/username/vibemeter-frontend
TAG=latest
