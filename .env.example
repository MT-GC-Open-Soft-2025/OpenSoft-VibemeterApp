# Copy this file to .env and fill in real values
# Used by docker-compose.yml and the backend at runtime

# --- Backend configuration ---
# MongoDB connection string
# Normal development uses the hosted MongoDB URL for your shared environment.
# The explicit local-infra workflow (`make dev-local`) overrides this with localhost.
# Example (MongoDB Atlas): mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=

# JWT settings
JWT_SECRET=
JWT_ALGORITHM=HS256
TOKEN_EXPIRY_SECONDS=3600

# Database name used by the app
DB_NAME=

# Optional: Google Gemini API key for AI chatbot features
GEMINI_KEY=

# Optional: AI model overrides (defaults shown)
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_TEMPERATURE=0.7
# GEMINI_MAX_OUTPUT_TOKENS=1024

# Comma-separated list of allowed CORS origins
# In production, restrict to your actual domains
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:80,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8100,http://127.0.0.1:8100

# --- Redis configuration (required for Redis Streams–backed streaming) ---
# Normal development uses the hosted Redis URL for your shared environment.
# The explicit local-infra workflow (`make dev-local`) overrides this with localhost.
# Leave empty to disable Redis-backed features.
REDIS_URL=
REDIS_DB=0

# --- Frontend build-time configuration ---
# Base URL the frontend uses to talk to the backend API
# For local dev or docker-compose runs, point to the exposed backend port
VITE_API_BASE_URL=http://localhost:8000

# --- Multi-agent local development ---
AGENT_SESSION_SIGNING_SECRET=wellbee-agent-session-secret
AGENT_INTERNAL_SYNC_SECRET=wellbee-agent-sync-secret
AGENT_BOOTSTRAP_TOKEN_TTL_SECONDS=300
AGENT_SEED_BASE_HOST=http://127.0.0.1

# Per-agent internal base URLs (backend→agent within Docker network).
# These override AGENT_SEED_BASE_HOST:<port> in production.
# Defaults in docker-compose use the Docker service names (e.g. http://agent-anchor:8101).
AGENT_SEED_ANCHOR_BASE_URL=
AGENT_SEED_SPARK_BASE_URL=
AGENT_SEED_SAGE_BASE_URL=

# Per-agent public base URLs (returned to the browser for direct SSE connections).
# In production these should be the HAProxy-fronted subdomains, e.g.:
#   AGENT_SEED_ANCHOR_PUBLIC_URL=https://anchor.wellbee.live
#   AGENT_SEED_SPARK_PUBLIC_URL=https://spark.wellbee.live
#   AGENT_SEED_SAGE_PUBLIC_URL=https://sage.wellbee.live
# Leave empty locally to fall back to AGENT_SEED_BASE_HOST:<port>.
AGENT_SEED_ANCHOR_PUBLIC_URL=
AGENT_SEED_SPARK_PUBLIC_URL=
AGENT_SEED_SAGE_PUBLIC_URL=

# CORS origins allowed by agents (browser-facing).
# In production set to the frontend domain(s).
AGENT_CORS_ORIGINS=https://wellbee.live,https://www.wellbee.live

# --- Image pull configuration (optional) ---
# Images are built and published automatically via GitHub Actions to ghcr.io.
# Override these only if you want to pull from a different registry/tag locally.
REGISTRY=ghcr.io/mt-gc-open-soft-2025
BACKEND_IMAGE=ghcr.io/mt-gc-open-soft-2025/vibemeter-backend
FRONTEND_IMAGE=ghcr.io/mt-gc-open-soft-2025/vibemeter-frontend
AGENT_RUNTIME_IMAGE=ghcr.io/mt-gc-open-soft-2025/wellbee-agent-runtime
TAG=latest

# --- Deployment / Watchtower (optional) ---
# Used only when running with docker-compose.watchtower.yml.
WATCHTOWER_POLL_INTERVAL_SECONDS=300
